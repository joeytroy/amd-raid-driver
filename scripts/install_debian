#!/bin/bash

# Modern Debian/Ubuntu installation script for rcraid driver
# Supports Ubuntu 18.04+, Debian 10+, and derivatives

set -e

DRIVER_NAME="rcraid"
KERNEL_VERSION="${1:-$(uname -r)}"
MODULE_PATH="/lib/modules/${KERNEL_VERSION}/kernel/drivers/scsi"
INITRAMFS_PATH="/boot/initrd.img-${KERNEL_VERSION}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if running as root
if [ "$EUID" -ne 0 ]; then
    log_error "This script must be run as root"
    exit 1
fi

# Check if kernel headers are available
if [ ! -d "/lib/modules/${KERNEL_VERSION}/build" ]; then
    log_error "Kernel headers for ${KERNEL_VERSION} not found"
    log_info "Please install kernel headers:"
    log_info "  Ubuntu/Debian: sudo apt install linux-headers-${KERNEL_VERSION}"
    exit 1
fi

# Check if driver module exists
if [ ! -f "${DRIVER_NAME}.ko" ]; then
    log_error "Driver module ${DRIVER_NAME}.ko not found"
    log_info "Please build the driver first: make"
    exit 1
fi

log_info "Installing ${DRIVER_NAME} driver for kernel ${KERNEL_VERSION}"

# Create module directory if it doesn't exist
mkdir -p "${MODULE_PATH}"

# Copy the driver module
cp "${DRIVER_NAME}.ko" "${MODULE_PATH}/"
log_info "Copied ${DRIVER_NAME}.ko to ${MODULE_PATH}/"

# Update module dependencies
depmod -a "${KERNEL_VERSION}"
log_info "Updated module dependencies"

# Add module to initramfs if it exists
if [ -f "${INITRAMFS_PATH}" ]; then
    log_info "Adding module to initramfs"
    
    # Backup original initramfs
    cp "${INITRAMFS_PATH}" "${INITRAMFS_PATH}.bak"
    
    # Update initramfs
    if command -v update-initramfs >/dev/null 2>&1; then
        update-initramfs -u -k "${KERNEL_VERSION}"
    elif command -v mkinitramfs >/dev/null 2>&1; then
        mkinitramfs -o "${INITRAMFS_PATH}" "${KERNEL_VERSION}"
    else
        log_warn "Could not update initramfs automatically"
    fi
fi

# Create modprobe configuration
MODPROBE_CONF="/etc/modprobe.d/${DRIVER_NAME}.conf"
cat > "${MODPROBE_CONF}" << EOF
# AMD RAID Controller Driver Configuration
# Generated by rcraid installer

# Blacklist conflicting drivers
blacklist ahci
blacklist sata_ahci

# Load rcraid driver
install ${DRIVER_NAME} /sbin/modprobe --ignore-install ${DRIVER_NAME}
EOF

log_info "Created modprobe configuration: ${MODPROBE_CONF}"

# Create udev rules for proper device naming
UDEV_RULES="/etc/udev/rules.d/99-${DRIVER_NAME}.rules"
cat > "${UDEV_RULES}" << EOF
# AMD RAID Controller udev rules
# Generated by rcraid installer

# Ensure proper device naming for RAID arrays
SUBSYSTEM=="block", KERNEL=="sd*", ATTRS{vendor}=="AMD", ATTRS{model}=="*RAID*", SYMLINK+="raid%n"
EOF

log_info "Created udev rules: ${UDEV_RULES}"

# Reload udev rules
if command -v udevadm >/dev/null 2>&1; then
    udevadm control --reload-rules
    log_info "Reloaded udev rules"
fi

log_info "Installation completed successfully!"
log_info "You may need to reboot for the changes to take effect."
log_info "To load the driver now, run: modprobe ${DRIVER_NAME}"

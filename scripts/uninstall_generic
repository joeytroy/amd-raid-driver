#!/bin/bash

# Generic Linux uninstallation script for rcraid driver
# Works with most Linux distributions

set -e

DRIVER_NAME="rcraid"
KERNEL_VERSION="${1:-$(uname -r)}"
MODULE_PATH="/lib/modules/${KERNEL_VERSION}/kernel/drivers/scsi"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if running as root
if [ "$EUID" -ne 0 ]; then
    log_error "This script must be run as root"
    exit 1
fi

log_info "Uninstalling ${DRIVER_NAME} driver for kernel ${KERNEL_VERSION}"

# Remove driver module
if [ -f "${MODULE_PATH}/${DRIVER_NAME}.ko" ]; then
    rm -f "${MODULE_PATH}/${DRIVER_NAME}.ko"
    log_info "Removed ${DRIVER_NAME}.ko from ${MODULE_PATH}/"
else
    log_warn "Driver module not found at ${MODULE_PATH}/${DRIVER_NAME}.ko"
fi

# Update module dependencies
depmod -a "${KERNEL_VERSION}"
log_info "Updated module dependencies"

# Remove modprobe configuration
MODPROBE_CONF="/etc/modprobe.d/${DRIVER_NAME}.conf"
if [ -f "${MODPROBE_CONF}" ]; then
    rm -f "${MODPROBE_CONF}"
    log_info "Removed modprobe configuration: ${MODPROBE_CONF}"
fi

# Remove udev rules
UDEV_RULES="/etc/udev/rules.d/99-${DRIVER_NAME}.rules"
if [ -f "${UDEV_RULES}" ]; then
    rm -f "${UDEV_RULES}"
    log_info "Removed udev rules: ${UDEV_RULES}"
fi

# Reload udev rules
if command -v udevadm >/dev/null 2>&1; then
    udevadm control --reload-rules
    log_info "Reloaded udev rules"
fi

# Unload module if loaded
if lsmod | grep -q "${DRIVER_NAME}"; then
    modprobe -r "${DRIVER_NAME}" 2>/dev/null || log_warn "Could not unload ${DRIVER_NAME} module"
fi

log_info "Uninstallation completed successfully!"
log_info "You may need to reboot for the changes to take effect."

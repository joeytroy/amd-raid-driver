# SPDX-License-Identifier: GPL-2.0-only
#
# rcraid module options — generated by install-dkms.sh
#
#   enable_writes=1
#     Allow writes to the RAID volume.  Off by default in the kernel module
#     for safety; this opt-in is recorded persistently so the array is
#     usable without extra modprobe args after install.
#
#   safe_subsys_vendor
#     Restrict rcraid to PCI devices whose subsystem_vendor matches this
#     value.  AMD's chipset shadows every NVMe behind 1022:b000, so without
#     this filter rcraid could try to claim the OS drive.

options rcraid enable_writes=1 safe_subsys_vendor=@SUBSYSTEM_VENDOR@
